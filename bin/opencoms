#!/usr/bin/env node

import { Command } from 'commander';
import fs from 'fs';
import path from 'path';
import { execSync, spawn } from 'child_process';

const HOME = process.env.HOME || process.env.USERPROFILE || '';
const OPENCOMS_DIR = path.join(HOME, '.opencoms');
const PID_FILE = path.join(OPENCOMS_DIR, 'server.pid');
const CONFIG_PATH = path.join(OPENCOMS_DIR, 'config.json');
const APP_DIR = path.join(OPENCOMS_DIR, 'app');

function loadConfig() {
  try {
    if (fs.existsSync(CONFIG_PATH)) {
      return JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf-8'));
    }
  } catch {}
  return {};
}

function isRunning(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function getServerPid() {
  try {
    if (fs.existsSync(PID_FILE)) {
      const pid = parseInt(fs.readFileSync(PID_FILE, 'utf-8').trim());
      if (isRunning(pid)) return pid;
      // Stale PID file
      fs.unlinkSync(PID_FILE);
    }
  } catch {}
  return null;
}

const program = new Command();

program
  .name('opencoms')
  .description('OpenComs — Fully Local Private Document Chat')
  .version('1.0.0');

program
  .command('start')
  .description('Start OpenComs server')
  .option('--folder <path>', 'Path to documents folder')
  .option('--port <number>', 'Port number (default: 4545)', '4545')
  .option('--verbose', 'Enable verbose logging')
  .option('--no-browser', 'Do not open browser automatically')
  .action(async (options) => {
    const existingPid = getServerPid();
    if (existingPid) {
      const config = loadConfig();
      const port = config.port || 4545;
      console.log(`\n  OpenComs is already running (PID: ${existingPid})`);
      console.log(`  Open http://localhost:${port} in your browser.\n`);
      return;
    }

    console.log('\n  Starting OpenComs...\n');
    console.log('  ╔══════════════════════════════════════════════╗');
    console.log('  ║  OpenComs — Private Document Chat            ║');
    console.log('  ║  Everything runs locally on your computer.   ║');
    console.log('  ║  Nothing leaves your machine.                ║');
    console.log('  ╚══════════════════════════════════════════════╝\n');

    // Determine server entry point
    const serverEntry = path.join(APP_DIR, 'server', 'dist', 'index.js');
    const devEntry = path.join(process.cwd(), 'server', 'dist', 'index.js');
    const tsDevEntry = path.join(process.cwd(), 'server', 'src', 'index.ts');

    let entry;
    let useTsx = false;

    if (fs.existsSync(serverEntry)) {
      entry = serverEntry;
    } else if (fs.existsSync(devEntry)) {
      entry = devEntry;
    } else if (fs.existsSync(tsDevEntry)) {
      entry = tsDevEntry;
      useTsx = true;
    } else {
      console.error('  ✗ Could not find OpenComs server files.');
      console.error('  Try running: cd ~/.opencoms/app && npm run build');
      process.exit(1);
    }

    const args = ['--start'];
    if (options.folder) args.push('--folder', options.folder);
    if (options.port) args.push('--port', options.port);
    if (options.verbose) args.push('--verbose');
    if (options.noBrowser === false) args.push('--no-browser');

    const child = spawn(
      useTsx ? 'npx' : 'node',
      useTsx ? ['tsx', entry, ...args] : [entry, ...args],
      {
        stdio: 'inherit',
        cwd: fs.existsSync(APP_DIR) ? APP_DIR : process.cwd(),
        env: { ...process.env },
      }
    );

    child.on('error', (err) => {
      console.error(`  ✗ Failed to start server: ${err.message}`);
      process.exit(1);
    });
  });

program
  .command('stop')
  .description('Stop OpenComs server')
  .action(() => {
    const pid = getServerPid();
    if (!pid) {
      console.log('\n  OpenComs is not running.\n');
      return;
    }

    try {
      process.kill(pid, 'SIGTERM');
      console.log(`\n  OpenComs stopped (PID: ${pid}).\n`);
      try { fs.unlinkSync(PID_FILE); } catch {}
    } catch (err) {
      console.error(`  ✗ Failed to stop server: ${err.message}`);
    }
  });

program
  .command('status')
  .description('Check OpenComs status')
  .action(async () => {
    const pid = getServerPid();
    const config = loadConfig();
    const port = config.port || 4545;

    console.log('\n  OpenComs Status');
    console.log('  ─────────────────────');

    if (pid) {
      console.log(`  Server:    Running (PID: ${pid})`);
      console.log(`  URL:       http://localhost:${port}`);
    } else {
      console.log('  Server:    Stopped');
    }

    console.log(`  Folder:    ${config.folder || 'Not set'}`);
    console.log(`  Model:     ${config.chatModel || 'llama3.2'}`);
    console.log(`  Data:      ~/.opencoms/`);
    console.log('');
  });

program
  .command('reindex')
  .description('Re-index all documents in the configured folder')
  .action(async () => {
    const config = loadConfig();
    const port = config.port || 4545;
    const pid = getServerPid();

    if (!pid) {
      console.log('\n  OpenComs is not running. Start it first: opencoms start\n');
      return;
    }

    if (!config.folder) {
      console.log('\n  No folder configured. Start OpenComs and select a folder first.\n');
      return;
    }

    console.log(`\n  Triggering reindex of: ${config.folder}\n`);

    try {
      const resp = await fetch(`http://127.0.0.1:${port}/api/reindex`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await resp.json();
      console.log(`  ${data.message}\n`);
    } catch (err) {
      console.error('  ✗ Could not reach OpenComs server. Is it running?\n');
    }
  });

program.parse();
