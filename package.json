{
  "name": "opencoms",
  "version": "1.0.0",
  "private": true,
  "description": "Fully local private document chat for macOS",
  "workspaces": ["server", "web"],
  "scripts": {
    "build": "npm run build --workspace=server && npm run build --workspace=web",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
